# ─────────────────────────────────────────────────────────────
# ProductReel AI — Environment Variables
# Copy this file to .env.local and fill in your keys.
# ─────────────────────────────────────────────────────────────

# ── BytePlus Ark API (main key — text + image + speech models) ──
BYTEPLUS_ARK_API_KEY=
BYTEPLUS_ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# ── Seedance 2.0 (Atlas Cloud — free $1 credit alternative) ──
# Sign up at https://atlascloud.ai to get a free API key
SEEDANCE_API_KEY=your_atlas_cloud_api_key_here
SEEDANCE_API_BASE_URL=https://api.atlascloud.ai/v1

# ── Model IDs (April 2026 current) ───────────────────────────
SEED2_MODEL_ID=seed-2-0-lite-260228
SEEDREAM_MODEL_ID=seedream-5-0-260128
SEEDANCE_MODEL_ID=dreamina-seedance-2-0-fast-260128
SEED_SPEECH_MODEL_ID=seed-tts-doubao
OMNI_HUMAN_MODEL_ID=omni-human-lite-fast-250515

# ── Demo mode (set to false to use real APIs) ─────────────────
# When true, all steps return realistic mock data instantly.
DEMO_MODE=true

# ── App config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
